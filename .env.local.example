# Anthropic API — required (server-only)
ANTHROPIC_API_KEY=

# Vercel Postgres / Neon — required for chat persistence
# Provided by `vercel env pull` once Vercel Postgres is provisioned.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Default user id (single-tenant v1 — hardcoded chat ownership)
DEFAULT_USER_ID=chloe

# Absolute path to the private prep corpus (mcf/AUDITIONS (!!)/_prep).
# Set locally to point at the symlinked Google Drive folder; on Vercel,
# point at where _prep/ lands in the build artifact (build-time copy in Phase 3).
# Left empty → only context/prompt/*.md is used.
MCF_PREP_DIR=

# Auth — passcode + signed cookie (middleware.ts + /api/login)
# AUTH_SECRET: HMAC key for the session cookie. Generate with `openssl rand -hex 32`.
# APP_PASSCODE: the shared passcode users enter on /login.
AUTH_SECRET=
APP_PASSCODE=

# Vercel Blob — auto-injected by the marketplace integration once linked.
# BLOB_READ_WRITE_TOKEN=
